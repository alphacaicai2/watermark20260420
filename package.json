{
  "name": "pdf-fixed-watermark-tool",
  "version": "0.1.0",
  "description": "Fixed-template PDF text watermark tool with NPM API, CLI, and MCP server.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "fonts",
    "scripts",
    "watermark.config.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./remote": {
      "types": "./dist/remote.d.ts",
      "import": "./dist/remote.js"
    }
  },
  "bin": {
    "pdfwm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/remote.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "commander": "^14.0.2",
    "express": "^5.2.1",
    "pdf-lib": "^1.17.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.7.0",
    "tsdown": "^0.15.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
